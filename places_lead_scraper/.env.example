# Copy this file to .env and fill in your actual values
# Never commit the .env file - it contains secrets!

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgres://user:password@localhost:5432/bizlead_db

# ============================================================================
# JWT & SECURITY
# ============================================================================
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars-!!!
JWT_SECRET=your-jwt-secret-key-change-this-in-production-min-32-chars-!!!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================================================
# API KEYS & EXTERNAL SERVICES
# ============================================================================
GOOGLE_PLACES_API_KEY=your-google-places-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================================================
# PAYMENT PROCESSOR SECRETS (Stripe/Razorpay)
# ============================================================================
STRIPE_API_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret_here
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
WEBHOOK_SECRET=your_generic_webhook_secret_key

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@bizlead.com

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=BizLead
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=production

# ============================================================================
# REDIS (for caching/sessions)
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# CORS & SECURITY
# ============================================================================
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_DIR=logs

# ============================================================================
# SUBSCRIPTION & BILLING
# ============================================================================
SUBSCRIPTION_DEFAULT_DURATION_DAYS=30
FREE_PLAN_LEAD_LIMIT=50
STARTER_PLAN_LEAD_LIMIT=500
PROFESSIONAL_PLAN_LEAD_LIMIT=2000
