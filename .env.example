# ============================================================================
# BIZLEAD ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and update with your actual values
# NEVER commit .env with real secrets to version control!

# ============================================================================
# APPLICATION
# ============================================================================
APP_NAME=BizLead
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_DIR=./logs

# ============================================================================
# DATABASE - POSTGRESQL OR SQLITE
# ============================================================================
# For Local Development (SQLite):
DATABASE_URL=sqlite:///./bizlead.db

# For Production (PostgreSQL on Render):
# DATABASE_URL=postgresql://user:password@hostname.render.com:5432/dbname

# ============================================================================
# MONGODB - For User & Subscription Management
# ============================================================================
# Local MongoDB:
MONGODB_URL=mongodb://admin:admin123@localhost:27017
MONGODB_DB_NAME=bizlead_db

# MongoDB Atlas (Production):
# MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/bizlead_db?retryWrites=true&w=majority

# ============================================================================
# SECURITY - CRYPTOGRAPHY & JWT
# ============================================================================
# Generate secure keys with: openssl rand -hex 32
SECRET_KEY=your-secret-key-min-32-characters-generated-with-openssl-rand-hex-32
JWT_SECRET=your-jwt-secret-min-32-characters-generated-with-openssl-rand-hex-32
ALGORITHM=HS256

# Token Expiry Times
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# GOOGLE APIs
# ============================================================================
# Get from: https://cloud.google.com/docs/authentication/api-keys
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ============================================================================
# PAYMENT PROCESSING (Optional - Choose one)
# ============================================================================

# Stripe
STRIPE_API_KEY=sk_test_your_stripe_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Razorpay (for India)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Generic Webhook Secret
WEBHOOK_SECRET=your-generic-webhook-secret

# ============================================================================
# EMAIL CONFIGURATION (Optional)
# ============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@bizlead.com

# For Gmail, use App Passwords (not regular password)
# https://myaccount.google.com/apppasswords

# ============================================================================
# REDIS CACHE (Optional)
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# CORS & SECURITY
# ============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ============================================================================
# USER PLAN LIMITS
# ============================================================================
FREE_PLAN_LEAD_LIMIT=50
STARTER_PLAN_LEAD_LIMIT=500
PROFESSIONAL_PLAN_LEAD_LIMIT=2000
ENTERPRISE_PLAN_LEAD_LIMIT=unlimited

# ============================================================================
# TRIAL CONFIGURATION
# ============================================================================
FREE_TRIAL_DAYS=7

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_EMAIL_VERIFICATION=false
ENABLE_TWO_FACTOR_AUTH=false
ENABLE_SOCIAL_LOGIN=false
ENABLE_PAYMENT_PROCESSING=true

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ============================================================================
# PROXY & NETWORK (if behind a proxy)
# ============================================================================
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1

# ============================================================================
# RENDER DEPLOYMENT (if using Render)
# ============================================================================
# DATABASE_URL is automatically set by Render
# Add other secrets in Render Dashboard → Environment

# ============================================================================
# NOTES
# ============================================================================
# 1. Generate secure keys:
#    openssl rand -hex 32
#
# 2. For local development:
#    - Use SQLite (DATABASE_URL=sqlite:///./bizlead.db)
#    - Use local MongoDB (docker-compose up -d mongodb)
#    - Set DEBUG=true
#
# 3. For production:
#    - Use PostgreSQL or managed database
#    - Use MongoDB Atlas or managed MongoDB
#    - Set DEBUG=false
#    - Use strong SECRET_KEY and JWT_SECRET
#    - Enable HTTPS/SSL
#    - Set proper CORS_ORIGINS
#
# 4. Never commit this file with real secrets!
#    Use: git rm --cached .env
